# Copy this file to .env and fill in values when your DeepSeek server is running

# URL base da sua API local DeepSeek (ex: Ollama, LM Studio, etc.)
# Formatos comuns:
#   Ollama:    http://192.168.1.100:11434/v1
#   LM Studio: http://192.168.1.100:1234/v1
EXPO_PUBLIC_AI_URL=http://localhost:11434/v1

# Nome do modelo (deixe como está para Ollama com DeepSeek)
EXPO_PUBLIC_AI_MODEL=deepseek-r1:latest
